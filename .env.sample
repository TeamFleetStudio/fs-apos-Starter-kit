########################################
# Core Application Settings
########################################

# Port the app will run on (optional; defaults to an auto-detected port in development)
PORT=3000

# Node environment: development | production
NODE_ENV=development

########################################
# Apostrophe / Database
########################################

# REQUIRED: MongoDB connection string.
# IMPORTANT: Include a database name and recommended query params:
#   mongodb://USER:PASS@host:27017/dbname?authSource=admin&tls=false
APOS_MONGODB_URI=mongodb://localhost:27017/a3-starter?authSource=admin&tls=false

# Base URL of the site, used for internal API calls in form submissions.
# In dev this can be left blank and will fall back to http://localhost:${PORT}
APOS_BASE_URL=http://localhost:3000

# Admin API key used for internal API calls from forms, etc.
APOS_ADMIN_API_KEY=your-admin-api-key-here

########################################
# File Uploads / UploadFS (S3)
########################################

# Storage driver, e.g. "s3"
APOS_STORAGE=s3

# S3 credentials and configuration
APOS_S3_KEY=your-s3-access-key
APOS_S3_SECRET=your-s3-secret-key
APOS_S3_BUCKET=your-s3-bucket-name
APOS_S3_REGION=your-s3-region

# Optional: app name prefix for uploads, used to build bucket prefix
APOS_S3_APP_NAME=fs-apostrophe-cms-starter

########################################
# Maps / Geocoding
########################################

# API key for your chosen node-geocoder provider (Mapbox, MapQuest, etc.)
GEOCODER_API_KEY=your-geocoder-api-key

########################################
# Forms / Google reCAPTCHA
########################################

# Google reCAPTCHA v3 site key and secret.
APOS_GOOGLE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
APOS_GOOGLE_RECAPTCHA_SECRET=your-recaptcha-secret-key

# Threshold for reCAPTCHA v3 scoring (0.0–1.0). 0.5 is a common default.
APOS_GOOGLE_RECAPTCHA_THRESHOLD=0.5

########################################
# Form Notifications / Slack
########################################

# Default Slack incoming webhook URL for form submission notifications.
APOS_SLACK_WEBHOOK_URL=your-slack-webhook-url

########################################
# Email / SMTP
########################################

# SMTP server settings (defaults in code: host=smtp.gmail.com, port=587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP credentials
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# From address for outgoing emails (falls back to SMTP_USER if not set)
SMTP_FROM=no-reply@example.com

########################################
# Release / Deployment (optional)
########################################

# Used by scripts/release-tasks (usually auto-generated)
# APOS_RELEASE_ID=auto-generated-release-id